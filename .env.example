# Non-secret development configuration only. Never place real credentials here.
ENS_HOST=127.0.0.1
ENS_PORT=8765
ENS_DATABASE_PATH=./var/ens-leads.db
ENS_LOG_DIRECTORY=./var/logs
# Generate a fresh token for each manual development session; the Tauri host
# supplies an ephemeral token automatically.
ENS_SESSION_TOKEN=replace-with-a-random-development-token-at-least-32-characters
VITE_ENS_API_URL=http://127.0.0.1:8765/api/v1
VITE_ENS_SESSION_TOKEN=replace-with-the-same-random-development-token
# Optional controlled discovery. Keep this secret out of source control.
ENS_GOOGLE_PLACES_API_KEY=
ENS_DISCOVERY_MAX_RESULTS=40
ENS_DISCOVERY_MAX_QUERIES=3
