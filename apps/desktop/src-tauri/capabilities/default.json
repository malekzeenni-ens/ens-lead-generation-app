{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal permissions for the main Etch N Shine window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://www.facebook.com/*"
        },
        {
          "url": "https://www.google.com/*"
        },
        {
          "url": "https://www.instagram.com/*"
        },
        {
          "url": "https://wa.me/*"
        },
        {
          "url": "https://ig.me/*"
        },
        {
          "url": "mailto:*"
        },
        {
          "url": "https://*"
        },
        {
          "url": "http://*"
        }
      ]
    }
  ]
}
