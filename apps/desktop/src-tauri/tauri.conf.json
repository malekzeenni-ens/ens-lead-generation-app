{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Etch N Shine Lead Generation",
  "version": "0.1.0",
  "identifier": "uk.co.etchnshine.leadgeneration",
  "build": {
    "beforeDevCommand": "npm.cmd --prefix ../frontend run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../../scripts/build-backend-sidecar.ps1 && npm.cmd --prefix ../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "title": "Etch ’N’ Shine Lead Generation",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "resources/ens-backend/": "ens-backend/"
    },
    "shortDescription": "Local lead-intelligence workbench",
    "longDescription": "Local, evidence-backed lead intelligence and controlled outreach preparation for Etch N Shine."
  }
}
